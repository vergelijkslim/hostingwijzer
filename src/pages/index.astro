---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import '../lib/affiliate-data';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Vergelijk Uw Hosting',
  url: Astro.site?.href,
  description: 'Onafhankelijke gids voor webhosting, VPS en cloud hosting in Nederland',
  inLanguage: 'nl',
};

const allArticles = (await getCollection('hosting'))
  .filter((a) => !a.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const featured = allArticles.filter((a) => a.data.featured).slice(0, 3);
const latest = allArticles.slice(0, 6);

const gidsen = allArticles.filter((a) => a.data.type === 'gids');
const vergelijkingen = allArticles.filter((a) => a.data.type === 'vergelijking');

const typeLabels: Record<string, string> = {
  vergelijking: 'Vergelijking',
  review: 'Review',
  gids: 'Gids',
};

const sections = [
  {
    title: 'Gidsen & Advies',
    description: 'Uitgebreide handleidingen over hosting types, migratie en beveiliging.',
    href: '/gidsen/',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
    count: gidsen.length,
  },
  {
    title: 'Vergelijkingen',
    description: 'Vergelijk hosting providers, VPS en cloud oplossingen naast elkaar.',
    href: '/vergelijkingen/',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
    count: vergelijkingen.length,
  },
  {
    title: 'Reviews',
    description: 'Diepgaande reviews van de populairste Nederlandse hosting providers.',
    href: '/artikelen/',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
    count: allArticles.filter((a) => a.data.type === 'review').length,
  },
];
---

<BaseLayout
  title="Vergelijk Uw Hosting"
  description="Onafhankelijk advies over webhosting, VPS, cloud hosting en domeinen. Vergelijk providers en vind de beste hosting voor jouw website."
  structuredData={structuredData}
>
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <span class="hero-eyebrow">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          Hosting vergelijker
        </span>
        <h1>Vind de beste<br /><em>webhosting</em> voor jou</h1>
        <p class="hero-sub">
          Onafhankelijk getest. Nederlandse providers vergeleken op snelheid, uptime en support.
          Bijgewerkt april 2026.
        </p>
        <div class="hero-stats">
          <div class="stat">
            <span class="stat-num">20+</span>
            <span class="stat-label">Providers getest</span>
          </div>
          <div class="stat">
            <span class="stat-num">99,9%</span>
            <span class="stat-label">Uptime vereiste</span>
          </div>
          <div class="stat">
            <span class="stat-num">100%</span>
            <span class="stat-label">Onafhankelijk</span>
          </div>
        </div>
        <div class="hero-cta-row">
          <a href="/offerte/" class="btn btn-cta">Vergelijk hosting pakketten</a>
          <a href="/zo-vergelijken-wij/" class="btn btn-ghost">Hoe wij testen →</a>
        </div>
      </div>
      <div class="hero-visual" aria-hidden="true">
        <!-- Server rack SVG illustration -->
        <svg viewBox="0 0 300 340" fill="none" xmlns="http://www.w3.org/2000/svg" class="server-illustration">
          <!-- Server rack frame -->
          <rect x="50" y="20" width="200" height="300" rx="12" fill="rgba(255,255,255,0.06)" stroke="rgba(255,255,255,0.15)" stroke-width="2"/>
          <!-- Rack units -->
          <!-- Server 1 - active (blue glow) -->
          <rect x="65" y="40" width="170" height="38" rx="6" fill="rgba(96,165,250,0.2)" stroke="rgba(96,165,250,0.5)" stroke-width="1.5"/>
          <rect x="75" y="50" width="80" height="6" rx="3" fill="rgba(255,255,255,0.3)"/>
          <rect x="75" y="62" width="50" height="4" rx="2" fill="rgba(255,255,255,0.15)"/>
          <circle cx="218" cy="57" r="5" fill="#60a5fa"/>
          <circle cx="205" cy="57" r="3.5" fill="rgba(255,255,255,0.2)"/>
          <!-- Server 2 - active -->
          <rect x="65" y="88" width="170" height="38" rx="6" fill="rgba(96,165,250,0.15)" stroke="rgba(96,165,250,0.35)" stroke-width="1.5"/>
          <rect x="75" y="98" width="65" height="6" rx="3" fill="rgba(255,255,255,0.25)"/>
          <rect x="75" y="110" width="40" height="4" rx="2" fill="rgba(255,255,255,0.12)"/>
          <circle cx="218" cy="105" r="5" fill="#34d399"/>
          <circle cx="205" cy="105" r="3.5" fill="rgba(255,255,255,0.2)"/>
          <!-- Server 3 - active -->
          <rect x="65" y="136" width="170" height="38" rx="6" fill="rgba(96,165,250,0.15)" stroke="rgba(96,165,250,0.35)" stroke-width="1.5"/>
          <rect x="75" y="146" width="72" height="6" rx="3" fill="rgba(255,255,255,0.25)"/>
          <rect x="75" y="158" width="45" height="4" rx="2" fill="rgba(255,255,255,0.12)"/>
          <circle cx="218" cy="153" r="5" fill="#34d399"/>
          <circle cx="205" cy="153" r="3.5" fill="rgba(255,255,255,0.2)"/>
          <!-- Server 4 - warning -->
          <rect x="65" y="184" width="170" height="38" rx="6" fill="rgba(251,191,36,0.1)" stroke="rgba(251,191,36,0.3)" stroke-width="1.5"/>
          <rect x="75" y="194" width="58" height="6" rx="3" fill="rgba(255,255,255,0.2)"/>
          <rect x="75" y="206" width="35" height="4" rx="2" fill="rgba(255,255,255,0.1)"/>
          <circle cx="218" cy="201" r="5" fill="#fbbf24"/>
          <circle cx="205" cy="201" r="3.5" fill="rgba(255,255,255,0.15)"/>
          <!-- Network switch at bottom -->
          <rect x="65" y="232" width="170" height="28" rx="5" fill="rgba(255,255,255,0.08)" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>
          <rect x="75" y="240" width="8" height="12" rx="2" fill="rgba(96,165,250,0.5)"/>
          <rect x="87" y="240" width="8" height="12" rx="2" fill="rgba(96,165,250,0.5)"/>
          <rect x="99" y="240" width="8" height="12" rx="2" fill="rgba(96,165,250,0.4)"/>
          <rect x="111" y="240" width="8" height="12" rx="2" fill="rgba(96,165,250,0.5)"/>
          <rect x="123" y="240" width="8" height="12" rx="2" fill="rgba(52,211,153,0.5)"/>
          <rect x="135" y="240" width="8" height="12" rx="2" fill="rgba(52,211,153,0.4)"/>
          <!-- Patch panel -->
          <rect x="65" y="268" width="170" height="20" rx="4" fill="rgba(255,255,255,0.05)" stroke="rgba(255,255,255,0.12)" stroke-width="1"/>
          <circle cx="80" cy="278" r="4" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>
          <circle cx="95" cy="278" r="4" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>
          <circle cx="110" cy="278" r="4" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>
          <circle cx="125" cy="278" r="4" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>
          <!-- Cables at bottom -->
          <path d="M85 288 Q85 300 100 305 Q120 308 140 306" stroke="rgba(96,165,250,0.4)" stroke-width="3" stroke-linecap="round" fill="none"/>
          <path d="M110 288 Q110 302 130 308" stroke="rgba(52,211,153,0.4)" stroke-width="3" stroke-linecap="round" fill="none"/>
          <!-- Ambient glow -->
          <ellipse cx="150" cy="160" rx="80" ry="120" fill="rgba(96,165,250,0.04)"/>
        </svg>
        <!-- Float badges -->
        <div class="float-badge float-badge-1">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span>99,9% uptime getest</span>
        </div>
        <div class="float-badge float-badge-2">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span>Bijgewerkt april 2026</span>
        </div>
      </div>
    </div>
  </section>

  <section class="trust-bar">
    <div class="container">
      <div class="trust-items">
        <div class="trust-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span>Onafhankelijk getest</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          <span>20+ providers vergeleken</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>Eerlijke vergelijkingen</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span>Bijgewerkt april 2026</span>
        </div>
      </div>
    </div>
  </section>

  <section class="sections" id="onderwerpen">
    <div class="container">
      <div class="section-header">
        <h2>Onze onderwerpen</h2>
        <p>Alles wat je moet weten over webhosting, van shared hosting tot dedicated servers.</p>
      </div>
      <div class="section-grid">
        {sections.map((section) => (
          <a href={section.href} class="section-card">
            <div class="section-icon">
              <Fragment set:html={section.icon} />
            </div>
            <h3>{section.title}</h3>
            <p>{section.description}</p>
            <span class="section-meta">{section.count} artikelen &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {featured.length > 0 && (
    <section class="featured">
      <div class="container">
        <div class="section-header">
          <h2>Uitgelichte artikelen</h2>
          <p>Onze meest gelezen gidsen en vergelijkingen.</p>
        </div>
        <div class="featured-grid">
          {featured.map((article) => (
            <a href={`/hosting/${article.id}/`} class="featured-card">
              <div class="featured-card-top">
                <span class="badge badge-amber">{typeLabels[article.data.type] || article.data.type}</span>
              </div>
              <h3>{article.data.title}</h3>
              <p>{article.data.description}</p>
              <div class="featured-card-meta">
                <span>{article.data.author}</span>
                <span>&middot;</span>
                <span>{article.data.publishDate.toLocaleDateString('nl-NL', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {latest.length > 0 && (
    <section class="latest">
      <div class="container">
        <div class="section-header">
          <h2>Laatste artikelen</h2>
          <p>Recent gepubliceerd en bijgewerkt.</p>
        </div>
        <div class="latest-grid">
          {latest.map((article) => (
            <a href={`/hosting/${article.id}/`} class="latest-card">
              <span class="badge badge-primary">{typeLabels[article.data.type] || article.data.type}</span>
              <h3>{article.data.title}</h3>
              <p>{article.data.description}</p>
            </a>
          ))}
        </div>
        <div class="view-all">
          <a href="/artikelen/" class="btn btn-primary">Bekijk alle artikelen</a>
        </div>
      </div>
    </section>
  )}

  <section class="offerte-cta">
    <div class="container">
      <div class="offerte-cta-card">
        <h2>Klaar voor de juiste hosting?</h2>
        <p>Vergelijk de beste hosting providers van Nederland en vind het pakket dat bij jou past. Bespaar op hosting zonder in te leveren op kwaliteit.</p>
        <div class="offerte-cta-buttons">
          <a href="/offerte/" class="btn btn-cta">Vergelijk hosting pakketten</a>
        </div>
        <p class="offerte-note"><small>100% onafhankelijk &middot; Eerlijke vergelijkingen &middot; Nederlandse providers</small></p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, #0c1445 0%, #1e3a8a 40%, #2563eb 70%, #3b82f6 100%);
    color: #fff;
    padding: 3rem 0 4rem;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 70% 50%, rgba(96,165,250,0.12) 0%, transparent 60%);
    pointer-events: none;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
    position: relative;
  }
  @media (min-width: 900px) {
    .hero { padding: 5rem 0 6rem; }
    .hero-inner { grid-template-columns: 1fr 1fr; gap: 4rem; }
  }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.875rem;
    background: rgba(96,165,250,0.2);
    border: 1px solid rgba(96,165,250,0.4);
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    color: #bfdbfe;
  }
  .hero h1 {
    color: #fff;
    font-size: 2.25rem;
    line-height: 1.15;
    margin-bottom: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .hero h1 em {
    font-style: normal;
    color: #93c5fd;
  }
  @media (min-width: 768px) { .hero h1 { font-size: 3rem; } }
  .hero-sub {
    font-size: 1.0625rem;
    opacity: 0.85;
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 480px;
  }
  .hero-stats {
    display: flex;
    gap: 2rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .stat-num {
    display: block;
    font-size: 1.5rem;
    font-weight: 800;
    color: #93c5fd;
    line-height: 1;
  }
  .stat-label {
    display: block;
    font-size: 0.8rem;
    opacity: 0.7;
    margin-top: 0.125rem;
  }
  .hero-cta-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .btn-ghost {
    background: transparent;
    color: #fff;
    border: none;
    padding: 0;
    font-weight: 500;
    opacity: 0.8;
  }
  .btn-ghost:hover {
    opacity: 1;
    box-shadow: none;
    transform: none;
    text-decoration: none;
    color: #93c5fd;
  }
  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .server-illustration {
    width: 100%;
    max-width: 260px;
    margin: 0 auto;
    filter: drop-shadow(0 20px 40px rgba(59,130,246,0.2));
  }
  @media (min-width: 900px) { .server-illustration { max-width: 300px; } }
  .float-badge {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.875rem;
    background: rgba(255,255,255,0.95);
    border-radius: 999px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #0c1445;
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
    white-space: nowrap;
  }
  .float-badge-1 { top: 10%; left: -10px; }
  .float-badge-2 { bottom: 15%; right: -10px; }

  .trust-bar {
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 0;
  }
  .trust-items {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-light);
  }
  .trust-item svg { color: var(--color-primary); flex-shrink: 0; }
  .trust-divider {
    width: 1px;
    height: 1.25rem;
    background: var(--color-border);
  }
  @media (max-width: 600px) { .trust-divider { display: none; } }
  @media (min-width: 768px) {
    .trust-items { gap: 2rem; }
  }

  .section-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .section-header p {
    color: var(--color-text-light);
    font-size: 1.0625rem;
    margin-top: 0.5rem;
  }

  .sections {
    padding: 4rem 0;
  }
  .section-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .section-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .section-card {
    display: block;
    padding: 2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    color: var(--color-text);
    background: var(--color-bg);
    transition: all var(--transition-base);
  }
  .section-card:hover {
    text-decoration: none;
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
    border-color: var(--color-primary-light);
  }
  .section-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-lg);
    margin-bottom: 1.25rem;
    background: var(--color-primary-light);
    color: var(--color-primary);
  }
  .section-card h3 {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .section-card p {
    color: var(--color-text-light);
    font-size: 0.9375rem;
    margin-bottom: 1rem;
    line-height: 1.6;
  }
  .section-meta {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  .featured {
    padding: 4rem 0;
    background: var(--color-bg-alt);
  }
  .featured-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) {
    .featured-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .featured-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .featured-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-text);
    transition: all var(--transition-base);
  }
  .featured-card:hover {
    text-decoration: none;
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .featured-card-top {
    margin-bottom: 0.75rem;
  }
  .featured-card h3 {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 0.5rem;
  }
  .featured-card p {
    color: var(--color-text-light);
    font-size: 0.875rem;
    line-height: 1.6;
    flex: 1;
  }
  .featured-card-meta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border-light);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .latest {
    padding: 4rem 0;
  }
  .latest-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .latest-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .latest-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .latest-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-text);
